name: Article Meilleur Podcast Semaine

on:
  workflow_dispatch:
    inputs:
      rss_url:
        description: "Flux RSS du podcast (vide = secret RSS_URL)"
        required: false
        default: "https://anchor.fm/s/fd06c6f8/podcast/rss"
      episode_index:
        description: "Index episode (0=dernier, 1=avant-dernier...)"
        required: false
        default: "0"
      categorie:
        description: "Categorie"
        required: false
        default: "Tech & Innovation"
      spotify_url:
        description: "Lien Spotify episode"
        required: false
        default: "https://open.spotify.com/episode/52hCBVCmhdW4lRqniIQEao"
      linkedin_url:
        description: "Profil LinkedIn hote"
        required: false
        default: "https://www.linkedin.com/company/aufildutextile/posts/?feedView=all"

jobs:
  generate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: actions/setup-python@v4
        with:
          python-version: "3.11"
      - name: Install dependencies
        run: pip install requests --break-system-packages
      - name: Install ffmpeg
        run: sudo apt-get install -y ffmpeg
      - name: Generate article
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          OPENAI_API_KEY: ${{ secrets.OPENAI_API_KEY }}
          RSS_URL: ${{ github.event.inputs.rss_url || secrets.RSS_URL }}
          BLOG_NAME: ${{ secrets.BLOG_NAME }}
          LISTENLY_PODCAST_URL: ${{ secrets.LISTENLY_PODCAST_URL }}
          CATEGORIE: ${{ github.event.inputs.categorie }}
          SPOTIFY_URL: ${{ github.event.inputs.spotify_url }}
          LINKEDIN_URL: ${{ github.event.inputs.linkedin_url }}
          EPISODE_INDEX: ${{ github.event.inputs.episode_index }}
          OUTPUT_DIR: articles
        run: python automation/scripts/generate_article_semaine.py
      - name: Deploy FTP
        uses: SamKirkland/FTP-Deploy-Action@v4.3.4
        with:
          server: ${{ secrets.FTP_SERVER }}
          username: ${{ secrets.FTP_USERNAME }}
          password: ${{ secrets.FTP_PASSWORD }}
          local-dir: articles/
          server-dir: ${{ secrets.FTP_REMOTE_DIR }}article-faq/semaine/
